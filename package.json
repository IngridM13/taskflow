{
  "name": "taskflow",
  "private": true,
  "workspaces": ["apps/api", "apps/web"],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/api\" \"npm run dev --workspace=apps/web\"",
    "lint": "npm run lint --workspaces --if-present",
    "test:unit": "npm run test:unit --workspace=apps/api",
    "test:integration": "npm run test:integration --workspace=apps/api",
    "test:bdd": "npm run test:bdd --workspace=apps/api",
    "test:e2e": "npx playwright test",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:bdd && npm run test:e2e"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "@playwright/test": "^1.44.0",
    "@cucumber/cucumber": "^10.8.0",
    "typescript": "^5.4.5"
  }
}

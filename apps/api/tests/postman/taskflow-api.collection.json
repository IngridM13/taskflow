                "exec": [
                  "pm.test('Status 201 Created', () => {\r",
                  " pm.response.to.have.status(201);\r",
                  "});\r",
                  "pm.test('Response tiene id y email', () => {\r",
                  " const body = pm.response.json();\r",
                  " pm.expect(body.user).to.have.property('id');\r",
                  " pm.expect(body.user.email).to.eql('facu6@ejemplo.com');\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],

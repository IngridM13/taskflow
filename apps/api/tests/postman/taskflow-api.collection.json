              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Tarea creada con status TODO', () => {\r",
                  " pm.response.to.have.status(201);\r",
                  " const body = pm.response.json();\r",
                  " pm.expect(body.status).to.eql('TODO');\r",
                  " pm.environment.set('task_id', body.id);\r",
                  "});\r",
                  "pm.test('Priority HIGH se persistió correctamente', () => {\r",
                  " pm.expect(pm.response.json().priority).to.eql('HIGH');\r",
                  "});"
